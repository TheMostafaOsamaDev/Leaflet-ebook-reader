{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Leaflet",
  "version": "0.1.0",
  "identifier": "com.leaflet.reader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Leaflet — E-Book Reader",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/leaflet/**", "$APPLOCALDATA/leaflet/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
